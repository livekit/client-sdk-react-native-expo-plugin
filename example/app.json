{
  "expo": {
    "name": "react-native-expo-plugin-example",
    "slug": "react-native-expo-plugin-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.livekit.reactnative.expo.example",
      "bitcode": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "io.livekit.reactnative.expo.example",
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "436b85b6-499e-427e-b3be-50f71b1d66bc"
      }
    },
    "plugins": [
      [
        "../app.plugin.js",
        {
          "android": {
            "audioType": "media",
            "enableScreenShareService": true
          },
          "ios": {
            "enableMultitaskingCameraAccess": true
          }
        }
      ],
      "@config-plugins/react-native-webrtc"
    ]
  }
}
